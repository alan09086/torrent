From: Alan <alan.c.gaudet@gmail.com>
Date: Wed, 4 Mar 2026 03:05:28 -0500
Subject: [PATCH 10/12] bench: add criterion disk write benchmarks (M57)

Co-Authored-By: Claude <noreply@anthropic.com>
---
 crates/ferrite-session/Cargo.toml            |   5 +
 crates/ferrite-session/benches/disk_write.rs | 123 +++++++++++++++++++
 2 files changed, 128 insertions(+)
 create mode 100644 crates/ferrite-session/benches/disk_write.rs

diff --git a/crates/ferrite-session/Cargo.toml b/crates/ferrite-session/Cargo.toml
index 0e8e7f8..224dd16 100644
--- a/crates/ferrite-session/Cargo.toml
+++ b/crates/ferrite-session/Cargo.toml
@@ -33,3 +33,8 @@ url = "2"
 pretty_assertions = { workspace = true }
 serde_json = "1"
 tokio = { workspace = true, features = ["full"] }
+criterion = { version = "0.5", features = ["async_tokio"] }
+
+[[bench]]
+name = "disk_write"
+harness = false
diff --git a/crates/ferrite-session/benches/disk_write.rs b/crates/ferrite-session/benches/disk_write.rs
new file mode 100644
index 0000000..b30565f
--- /dev/null
+++ b/crates/ferrite-session/benches/disk_write.rs
@@ -0,0 +1,123 @@
+use bytes::Bytes;
+use criterion::{BenchmarkId, Criterion, Throughput, criterion_group, criterion_main};
+use ferrite_core::{Id20, Lengths};
+use ferrite_session::disk::{DiskConfig, DiskJobFlags, DiskManagerHandle};
+use ferrite_storage::MemoryStorage;
+use std::sync::Arc;
+use tokio::runtime::Runtime;
+
+fn test_config() -> DiskConfig {
+    DiskConfig {
+        io_threads: 2,
+        cache_size: 1024 * 1024,
+        ..DiskConfig::default()
+    }
+}
+
+fn make_hash(n: u8) -> Id20 {
+    let mut b = [0u8; 20];
+    b[0] = n;
+    Id20(b)
+}
+
+fn bench_write_chunk(c: &mut Criterion) {
+    let rt = Runtime::new().unwrap();
+    let mut group = c.benchmark_group("disk_write");
+
+    for block_size in [16384u32, 65536, 262144] {
+        group.throughput(Throughput::Bytes(block_size as u64));
+        group.bench_with_input(
+            BenchmarkId::new("write_chunk_blocking", block_size),
+            &block_size,
+            |b, &size| {
+                b.to_async(&rt).iter(|| async move {
+                    let ih = make_hash(1);
+                    let total = size as u64 * 256;
+                    let lengths = Lengths::new(total, size as u64, size);
+                    let (mgr, _actor) = DiskManagerHandle::new(test_config());
+                    let storage = Arc::new(MemoryStorage::new(lengths));
+                    let disk = mgr.register_torrent(ih, storage).await;
+
+                    let data = Bytes::from(vec![0xABu8; size as usize]);
+                    disk.write_chunk(0, 0, data, DiskJobFlags::empty())
+                        .await
+                        .unwrap();
+
+                    mgr.shutdown().await;
+                });
+            },
+        );
+    }
+    group.finish();
+}
+
+fn bench_write_burst(c: &mut Criterion) {
+    let rt = Runtime::new().unwrap();
+    let mut group = c.benchmark_group("disk_write_burst");
+
+    // Simulate a burst of 256 blocks (one full 4MB piece at 16KB blocks)
+    let num_blocks = 256u32;
+    let block_size = 16384u32;
+    group.throughput(Throughput::Bytes((num_blocks * block_size) as u64));
+
+    group.bench_function("256_blocks_blocking", |b| {
+        b.to_async(&rt).iter(|| async {
+            let ih = make_hash(2);
+            let total = (num_blocks * block_size) as u64 * 4;
+            let lengths = Lengths::new(total, (num_blocks * block_size) as u64, block_size);
+            let (mgr, _actor) = DiskManagerHandle::new(test_config());
+            let storage = Arc::new(MemoryStorage::new(lengths));
+            let disk = mgr.register_torrent(ih, storage).await;
+
+            for i in 0..num_blocks {
+                let data = Bytes::from(vec![0xABu8; block_size as usize]);
+                disk.write_chunk(0, i * block_size, data, DiskJobFlags::empty())
+                    .await
+                    .unwrap();
+            }
+
+            mgr.shutdown().await;
+        });
+    });
+
+    group.finish();
+}
+
+fn bench_enqueue_write_burst(c: &mut Criterion) {
+    let rt = Runtime::new().unwrap();
+    let mut group = c.benchmark_group("disk_enqueue_burst");
+
+    let num_blocks = 256u32;
+    let block_size = 16384u32;
+    group.throughput(Throughput::Bytes((num_blocks * block_size) as u64));
+
+    group.bench_function("256_blocks_enqueue", |b| {
+        b.to_async(&rt).iter(|| async {
+            let ih = make_hash(3);
+            let total = (num_blocks * block_size) as u64 * 4;
+            let lengths = Lengths::new(total, (num_blocks * block_size) as u64, block_size);
+            let (mgr, _actor) = DiskManagerHandle::new(test_config());
+            let storage = Arc::new(MemoryStorage::new(lengths));
+            let disk = mgr.register_torrent(ih, storage).await;
+
+            let (error_tx, _error_rx) = tokio::sync::mpsc::channel(64);
+            for i in 0..num_blocks {
+                let data = Bytes::from(vec![0xABu8; block_size as usize]);
+                let _ =
+                    disk.enqueue_write(0, i * block_size, data, DiskJobFlags::empty(), &error_tx);
+            }
+            // shutdown() waits for all pending writes to drain
+            mgr.shutdown().await;
+        });
+    });
+
+    group.finish();
+}
+
+criterion_group!(
+    benches,
+    bench_write_chunk,
+    bench_write_burst,
+    bench_enqueue_write_burst
+);
+criterion_main!(benches);
-- 
