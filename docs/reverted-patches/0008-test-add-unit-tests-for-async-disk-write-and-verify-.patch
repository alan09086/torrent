+    #[tokio::test]
+    async fn enqueue_write_no_error() {
+        let (mgr, _actor) = DiskManagerHandle::new(test_config());
+        let ih = make_hash(20);
+        let lengths = Lengths::new(100, 50, 25);
+        let storage = Arc::new(MemoryStorage::new(lengths));
+        let disk = mgr.register_torrent(ih, storage).await;
+
+        let (error_tx, mut error_rx) = mpsc::channel(64);
+        let data = Bytes::from(vec![42u8; 25]);
+        let result = disk.enqueue_write(0, 0, data, DiskJobFlags::empty(), &error_tx);
+        assert!(result.is_ok());
+
+        // Give disk actor time to process
+        tokio::time::sleep(std::time::Duration::from_millis(50)).await;
+
+        // No error should have been sent
+        assert!(error_rx.try_recv().is_err());
+
+        mgr.shutdown().await;
+    }
+
+    #[tokio::test]
+    async fn enqueue_verify_delivers_result() {
+        let (mgr, _actor) = DiskManagerHandle::new(test_config());
+        let ih = make_hash(21);
+        let lengths = Lengths::new(100, 50, 25);
+        let storage = Arc::new(MemoryStorage::new(lengths));
+        let disk = mgr.register_torrent(ih, storage).await;
+
+        // Write a full piece (50 bytes = 2 chunks of 25)
+        let piece_data = vec![9u8; 50];
+        disk.write_chunk(0, 0, Bytes::from(piece_data[..25].to_vec()), DiskJobFlags::empty())
+            .await
+            .unwrap();
+        disk.write_chunk(
+            0,
+            25,
+            Bytes::from(piece_data[25..].to_vec()),
+            DiskJobFlags::FLUSH_PIECE,
+        )
+        .await
+        .unwrap();
+
+        let expected = ferrite_core::sha1(&piece_data);
+        let (result_tx, mut result_rx) = mpsc::channel(64);
+        disk.enqueue_verify(0, expected, &result_tx);
+
+        // Wait for result
+        let result = tokio::time::timeout(std::time::Duration::from_secs(5), result_rx.recv())
+            .await
+            .unwrap()
+            .unwrap();
+
+        assert_eq!(result.piece, 0);
+        assert!(result.passed);
+
+        // Also test with wrong hash — should fail
+        let (result_tx2, mut result_rx2) = mpsc::channel(64);
+        disk.enqueue_verify(0, Id20::ZERO, &result_tx2);
+
+        let result2 = tokio::time::timeout(std::time::Duration::from_secs(5), result_rx2.recv())
+            .await
+            .unwrap()
+            .unwrap();
+
+        assert_eq!(result2.piece, 0);
+        assert!(!result2.passed);
+
+        mgr.shutdown().await;
+    }
+
+    #[tokio::test]
+    async fn enqueue_write_data_readable() {
+        let (mgr, _actor) = DiskManagerHandle::new(test_config());
+        let ih = make_hash(22);
+        let lengths = Lengths::new(100, 50, 25);
+        let storage = Arc::new(MemoryStorage::new(lengths));
+        let disk = mgr.register_torrent(ih, storage).await;
+
+        let (error_tx, mut error_rx) = mpsc::channel(64);
+        let data = Bytes::from(vec![77u8; 25]);
+        disk.enqueue_write(0, 0, data.clone(), DiskJobFlags::FLUSH_PIECE, &error_tx)
+            .unwrap();
+
+        // Wait for write to complete
+        tokio::time::sleep(std::time::Duration::from_millis(100)).await;
+
+        // Read it back
+        let read = disk
+            .read_chunk(0, 0, 25, DiskJobFlags::empty())
+            .await
+            .unwrap();
+        assert_eq!(read, data);
+
+        // No write errors
+        assert!(error_rx.try_recv().is_err());
+
+        mgr.shutdown().await;
+    }
